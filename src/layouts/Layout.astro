---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "BG LEX Kancelaria Adwokacka - Profesjonalna pomoc prawna w eleganckim wydaniu." } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/BGLex/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | BG LEX Kancelaria Adwokacka` : 'BG LEX Kancelaria Adwokacka'}</title>
	</head>
	<body class="min-h-screen flex flex-col">
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--brand-dark: #043624;
		--brand-gold: #C99655;
	}
	html {
		scroll-behavior: smooth;
	}
</style>
