---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import { motion } from 'framer-motion';
import { Scale, Gavel, FileText, Users, ArrowRight, ShieldCheck, MapPin } from 'lucide-react';
---

<Layout title="Strona Główna">
	<Header client:load isTransparent={true} />
	
	<main>
		<!-- Hero Section -->
		<section class="relative h-screen flex items-center justify-center bg-brand-dark overflow-hidden">
			<!-- Background Image with Overlay -->
			<div class="absolute inset-0 z-0">
				<img 
					src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80" 
					alt="Kancelaria Adwokacka Tło" 
					class="w-full h-full object-cover opacity-30"
				/>
				<div class="absolute inset-0 bg-brand-dark/80"></div>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-brand-gold/10 via-transparent to-transparent"></div>
			</div>

			<div class="container mx-auto px-4 text-center z-10">
				<div class="inline-block mb-6">
					<div class="h-[1px] w-12 bg-brand-gold mx-auto mb-4"></div>
					<span class="text-brand-gold uppercase tracking-[0.4em] text-xs font-bold">Kancelaria Adwokacka</span>
				</div>
				<h1 class="text-5xl md:text-7xl lg:text-8xl text-white font-serif mb-8 leading-tight">
					Barbara Babka
				</h1>
				<p class="text-gray-300 max-w-2xl mx-auto text-lg md:text-xl font-light mb-12 leading-relaxed italic">
					"Prawo to nie tylko zbiór przepisów, to przede wszystkim dbałość o drugiego człowieka."
				</p>
				<div class="flex flex-col sm:flex-row gap-6 justify-center">
					<a href="#specjalizacje" class="bg-brand-gold text-brand-dark px-10 py-4 uppercase text-sm tracking-widest font-bold hover:bg-white transition-all duration-300">
						Nasze specjalizacje
					</a>
					<a href="/AdwokatBabka/#kontakt" class="border border-white text-white px-10 py-4 uppercase text-sm tracking-widest font-bold hover:bg-white hover:text-brand-dark transition-all duration-300">
						Kontakt
					</a>
				</div>
			</div>

			<!-- Scroll indicator -->
			<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
				<div class="w-[1px] h-12 bg-brand-gold/50"></div>
			</div>
		</section>

		<!-- Features/Trust Section -->
		<section class="py-24 bg-white">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
					<div class="text-center group">
						<div class="w-16 h-16 bg-brand-dark/5 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-brand-gold transition-colors duration-500">
							<ShieldCheck className="text-brand-gold group-hover:text-white transition-colors" size={32} />
						</div>
						<h3 class="text-xl font-serif mb-4">Doświadczenie</h3>
						<p class="text-gray-600 font-light text-sm leading-relaxed">
							Wieloletnia praktyka i setki rozwiązanych spraw pozwalają nam na skuteczne działanie w każdych warunkach.
						</p>
					</div>
					<div class="text-center group">
						<div class="w-16 h-16 bg-brand-dark/5 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-brand-gold transition-colors duration-500">
							<Users className="text-brand-gold group-hover:text-white transition-colors" size={32} />
						</div>
						<h3 class="text-xl font-serif mb-4">Zaufanie</h3>
						<p class="text-gray-600 font-light text-sm leading-relaxed">
							Relacja z klientem oparta na dyskrecji i pełnym zrozumieniu potrzeb jest dla nas priorytetem.
						</p>
					</div>
					<div class="text-center group">
						<div class="w-16 h-16 bg-brand-dark/5 rounded-full flex items-center justify-center mx-auto mb-6 group-hover:bg-brand-gold transition-colors duration-500">
							<Scale className="text-brand-gold group-hover:text-white transition-colors" size={32} />
						</div>
						<h3 class="text-xl font-serif mb-4">Skuteczność</h3>
						<p class="text-gray-600 font-light text-sm leading-relaxed">
							Dążymy do osiągnięcia najlepszych możliwych rezultatów, dbając o bezpieczeństwo prawne naszych klientów.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Practice Areas -->
		<section id="specjalizacje" class="py-24 bg-gray-50">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<span class="text-brand-gold uppercase tracking-[0.3em] text-xs font-bold mb-4 block">Specjalizacje</span>
					<h2 class="text-4xl md:text-5xl font-serif text-brand-dark">Obszary praktyki</h2>
					<div class="h-[1px] w-20 bg-brand-gold mx-auto mt-6"></div>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{[
						{ title: 'Prawo Cywilne', icon: Gavel, desc: 'Reprezentacja w sprawach o zapłatę, odszkodowania oraz sporach własnościowych.' },
						{ title: 'Prawo Rodzinne', icon: Users, desc: 'Rozwody, podziały majątku, sprawy o alimenty oraz kontakty z dziećmi.' },
						{ title: 'Prawo Karne', icon: ShieldCheck, desc: 'Obrona w sprawach karnych i wykroczeniowych na każdym etapie postępowania.' },
						{ title: 'Prawo Spadkowe', icon: FileText, desc: 'Stwierdzenie nabycia spadku, zachowek oraz dział spadku.' },
						{ title: 'Obsługa Firm', icon: Scale, desc: 'Stała pomoc prawna dla przedsiębiorców i spółek prawa handlowego.' },
						{ title: 'Nieruchomości', icon: MapPin, desc: 'Analiza prawna umów, regulowanie stanu prawnego nieruchomości.' },
					].map((item) => (
						<div class="bg-white p-10 border border-gray-100 hover:border-brand-gold transition-all duration-300 group shadow-sm hover:shadow-xl">
							<item.icon className="text-brand-gold mb-6 group-hover:scale-110 transition-transform" size={40} />
							<h4 class="text-xl font-serif mb-4 text-brand-dark">{item.title}</h4>
							<p class="text-gray-600 font-light text-sm mb-6 leading-relaxed">
								{item.desc}
							</p>
							{/* <a href="#" class="text-brand-gold text-xs uppercase tracking-widest font-bold flex items-center group-hover:translate-x-2 transition-transform">
								Szczegóły <ArrowRight size={14} className="ml-2" />
							</a> */}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Call to Action -->
		<section id="kontakt" class="py-24 bg-brand-dark relative overflow-hidden scroll-mt-[140px]">
			<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80')] bg-cover bg-center opacity-10"></div>
			<div class="container mx-auto px-4 relative z-10 text-center">
				<h2 class="text-4xl md:text-5xl font-serif text-white mb-8">Potrzebujesz profesjonalnej porady prawnej?</h2>
				<p class="text-gray-300 max-w-2xl mx-auto mb-12 font-light text-lg">
					Zapraszamy na konsultacje w naszej kancelarii. Razem znajdziemy najlepsze rozwiązanie Twojej sprawy.
				</p>
				<a href="tel:+48123456789" class="inline-flex items-center gap-4 bg-brand-gold text-brand-dark px-12 py-5 uppercase text-sm tracking-widest font-bold hover:bg-white transition-all duration-300">
					Zadzwoń teraz: +48 123 456 789
				</a>
			</div>
		</section>
	</main>

	<Footer client:load />
</Layout>
